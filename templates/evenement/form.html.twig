{% extends 'base.html.twig' %}
{% block title %}{{ title }}{% endblock %}
{% block breadcrumb %}Événements › {{ title }}{% endblock %}

{% block body %}
<div class="page-header">
    <h1>{{ title }}</h1>
    <a href="{{ path('evenement_index') }}" class="btn btn-outline">← Retour</a>
</div>

<div class="ag-card">
    {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

    <div class="form-grid cols-2">
        <div class="col-span-2">{{ form_row(form.formation) }}</div>
        <div>{{ form_row(form.dateDebut) }}</div>
        <div>{{ form_row(form.dateFin) }}</div>
        <div>{{ form_row(form.lieu) }}</div>
        <div>{{ form_row(form.type) }}</div>
        <div>{{ form_row(form.capaciteMax) }}</div>
        <div>{{ form_row(form.nombreInscrits) }}</div>
        <div>{{ form_row(form.statut) }}</div>
    </div>

    <div class="form-actions">
        <button class="btn btn-green">💾 Enregistrer</button>
        <a href="{{ path('evenement_index') }}" class="btn btn-outline">Annuler</a>
    </div>

    {{ form_end(form) }}
</div>
{% endblock %}
