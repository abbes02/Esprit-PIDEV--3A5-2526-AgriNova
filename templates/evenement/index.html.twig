{% extends 'parcelle/base.html.twig' %}

{% block title %}Evenements{% endblock %}

{% block body %}
<section class="page-panel reveal">
    <div class="section-head">
        <div>
            <div class="section-kicker"><i class="bi bi-calendar-week"></i> Agenda</div>
            <h1 class="page-title reveal-text">Evenements</h1>
            <p class="page-intro">{{ evenements|length }} resultat(s) disponibles.</p>
        </div>
        <div class="stack-sm">
            <a href="{{ path('evenement_pdf', { q: q }) }}" class="button-secondary">Exporter PDF</a>
            <a href="{{ path('evenement_new') }}" class="button-primary">Nouvel evenement</a>
        </div>
    </div>

    <form class="search-form mb-4" method="get">
        <div class="row g-3 align-items-end">
            <div class="col-md-8">
                <label for="evenement-search">Recherche</label>
                <input
                    id="evenement-search"
                    class="form-control"
                    type="search"
                    name="q"
                    value="{{ q }}"
                    placeholder="Formation, lieu, type, statut"
                >
            </div>
            <div class="col-md-4">
                <button class="button-primary w-100" type="submit">Rechercher</button>
            </div>
        </div>
    </form>

    <div class="table-shell">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Formation</th>
                        <th>Lieu</th>
                        <th>Type</th>
                        <th>Debut</th>
                        <th>Fin</th>
                        <th>Capacite</th>
                        <th>Inscrits</th>
                        <th>Statut</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="table-body">
                    {% include 'evenement/_table.html.twig' %}
                </tbody>
            </table>
        </div>
    </div>
</section>
{% endblock %}
