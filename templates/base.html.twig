                /* Severity Radio Group */
                .severity-radio-wrapper {
                    display: grid;
                    grid-template-columns: repeat(3, 1fr);
                    gap: 12px;
                }

                .severity-option {
                    position: relative;
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                    padding: 16px 12px;
                    border: 2px solid #e0e8e3;
                    border-radius: 12px;
                    background: #fff;
                    cursor: pointer;
                    transition: all 0.2s ease;
                    text-align: center;
                }

                .severity-option input[type="radio"] {
                    position: absolute;
                    opacity: 0;
                }

                .severity-option .severity-icon {
                    font-size: 24px;
                    margin-bottom: 8px;
                }

                .severity-option .severity-label {
                    font-weight: 700;
                    font-size: 14px;
                    margin-bottom: 4px;
                }

                .severity-option .severity-desc {
                    font-size: 11px;
                    color: #6b7c72;
                }

