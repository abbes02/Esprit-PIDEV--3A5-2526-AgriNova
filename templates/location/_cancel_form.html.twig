<form method="post" action="{{ path('app_location_cancel', {'id': location.id, 'user_id': current_user.id}) }}" onsubmit="return confirm('Cancel this location?');">
    <input type="hidden" name="_token" value="{{ csrf_token('cancel_location_' ~ location.id) }}">
    <button class="button secondary">Cancel</button>
</form>
