                    color: #1e3a2b;
                }

                .materiel-type {
                    display: block;
                    font-size: 12px;
                    color: #6b7c72;
                }

                .location-dates {
                    padding: 16px;
                }

                .date-range {
                    display: flex;
                    align-items: center;
                    justify-content: space-between;
                    gap: 12px;
                }

                .date-item {
                    text-align: center;
                }

                .date-label {
                    display: block;
                    font-size: 11px;
                    text-transform: uppercase;
                    letter-spacing: 0.05em;
                    color: #6b7c72;
                    margin-bottom: 4px;
                }

                .date-value {
                    font-size: 15px;
                    font-weight: 700;
                    color: #1e3a2b;
                }

                .date-arrow {
                    color: #9ca9a0;
                    font-size: 14px;
                }

                .location-progress {
                    margin-top: 14px;
                }

                .progress-bar {
                    height: 6px;
                    background: #e4efe8;
                    border-radius: 3px;
                    overflow: hidden;
                }

                .progress-fill {
                    height: 100%;
                    background: linear-gradient(90deg, #3b9e56 0%, #1d71b8 100%);
                    border-radius: 3px;
                    transition: width 0.3s ease;
                }

                .progress-text {
                    display: block;
                    margin-top: 6px;
                    font-size: 11px;
                    color: #6b7c72;
                    text-align: right;
                }

                .location-pricing {
                    padding: 16px;
                    background: linear-gradient(135deg, #f0faf3 0%, #e8f6ec 100%);
                    border-top: 1px solid #d4eede;
                }

                .pricing-main {
                    display: flex;
                    align-items: baseline;
                    gap: 8px;
                    margin-bottom: 8px;
                }

                .pricing-label {
                    font-size: 12px;
                    text-transform: uppercase;
                    letter-spacing: 0.05em;
                    color: #4a6b54;
                }

                .pricing-value {
                    font-size: 1.5rem;
                    font-weight: 800;
                    color: #1e7a3c;
                }

                .pricing-value small {
                    font-size: 0.5em;
                    font-weight: 600;
                }

                .pricing-details {
                    display: flex;
                    gap: 16px;
                    font-size: 13px;
                    color: #4a6b54;
                }

                .pricing-details i {
                    margin-right: 4px;
                    color: #8fb89c;
                }

                .location-card-actions {
                    padding: 12px 16px;
                    background: #f8fcf9;
                    border-top: 1px solid #e9f2ec;
                    display: flex;
                    gap: 8px;
                    flex-wrap: wrap;
                }

                /* Enhanced Marketplace Cards */
                .market-status-overlay {
                    position: absolute;
                    top: 10px;
                    left: 10px;
                    right: 10px;
                    display: flex;
                    justify-content: space-between;
                    align-items: flex-start;
                }

                .market-status {
                    position: static;
                    display: inline-flex;
                    align-items: center;
                    gap: 5px;
                }

                .owner-badge {
                    background: rgba(0,0,0,0.6);
                    color: #fff;
                    border-radius: 999px;
                    padding: 4px 10px;
                    font-size: 11px;
                    font-weight: 700;
                }

                .market-type-badge {
                    position: absolute;
                    bottom: 10px;
                    left: 10px;
                    background: rgba(255,255,255,0.95);
                    color: #2d5f40;
                    border-radius: 8px;
                    padding: 5px 10px;
                    font-size: 12px;
                    font-weight: 700;
                    display: inline-flex;
                    align-items: center;
                    gap: 5px;
                    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
                }

                .market-owner-row {
                    display: flex;
                    align-items: center;
                    gap: 8px;
                    font-size: 13px;
                    color: #5a6b62;
                }

                .market-owner-row i {
                    font-size: 16px;
                    color: #8fa498;
                }

                .market-price-main {
                    display: flex;
                    align-items: baseline;
                    gap: 4px;
                }

                .market-currency {
                    font-size: 14px;
                    font-weight: 600;
                    color: #4a6b54;
                }

                .market-panne-snippet.severity-critical {
                    border-color: #f5c3c3;
                    background: #fef2f2;
                }

                .market-panne-snippet.severity-critical .market-panne-label {
                    color: #b91c1c;
                }

                .market-panne-snippet.severity-major {
                    border-color: #f5d9a8;
                    background: #fef8eb;
                }

                .market-panne-snippet.severity-major .market-panne-label {
                    color: #9a6c00;
                }

                .market-card.is-owned {
                    border-color: #c5e3cf;
                }

                .owner-actions {
                    display: flex;
                    gap: 6px;
                    width: 100%;
                    margin-top: 4px;
                }

                .button.full-width {
                    flex: 1;
                    text-align: center;
                }

                .button.small {
                    padding: 6px 12px;
                    font-size: 13px;
                }

                .button.warning {
                    background: #d97706;
                }

                .button.warning:hover {
                    background: #b45309;
                }

                /* Info Boxes */
                .pricing-info-box, .pricing-tip-box {
                    display: flex;
                    align-items: flex-start;
                    gap: 12px;
                    padding: 14px;
                    background: #f0f9f4;
                    border: 1px solid #c8e6d0;
                    border-radius: 10px;
                    margin-top: 16px;
                }

                .pricing-info-box i, .pricing-tip-box i {
                    font-size: 18px;
                    color: #3b9e56;
                    margin-top: 2px;
                }

                .pricing-info-box strong, .pricing-tip-box strong {
                    display: block;
                    font-size: 13px;
                    color: #1e4a32;
                    margin-bottom: 4px;
                }

                .pricing-info-box p, .pricing-tip-box p {
                    margin: 0;
                    font-size: 12px;
                    color: #4a6b54;
                    line-height: 1.4;
                }

                /* Enhanced Rental Panel */
                .rental-panel-header {
                    margin-bottom: 12px;
                }

                .rental-panel-body {
                    text-align: center;
                }

                .rental-meta-item {
                    display: inline-flex;
                    align-items: center;
                    gap: 6px;
                }

                .rental-meta-item i {
                    color: #8fb89c;
                }

                /* Date Range Visual */
                .date-range-visual {
                    margin-top: 16px;
                    padding: 14px;
                    background: #f5f9f7;
                    border-radius: 10px;
                }

                .date-range-bar {
                    display: flex;
                    align-items: center;
                    gap: 12px;
                }

                .date-range-start, .date-range-end {
                    font-size: 13px;
                    font-weight: 700;
                    color: #1e4a32;
                    white-space: nowrap;
                }

                .date-range-line {
                    flex: 1;
                    height: 4px;
                    background: linear-gradient(90deg, #3b9e56 0%, #1d71b8 100%);
                    border-radius: 2px;
                }

                .date-range-summary {
                    margin: 8px 0 0;
                    text-align: center;
                    font-size: 13px;
                    color: #4a6b54;
                }

                /* Booked Periods Box */
                .booked-periods-box {
                    margin-top: 16px;
                    padding: 14px 16px;
                    background: #fef6e7;
                    border: 1px solid #f5d89a;
                    border-radius: 10px;
                }

                .booked-periods-header {
                    display: flex;
                    align-items: center;
                    gap: 8px;
                    color: #8a6914;
                    font-size: 14px;
                    margin-bottom: 10px;
                }

                .booked-periods-header i {
                    font-size: 16px;
                }

                .booked-periods-list {
                    list-style: none;
                    padding: 0;
                    margin: 0 0 10px 0;
                    display: flex;
                    flex-wrap: wrap;
                    gap: 8px;
                }

                .booked-periods-list li {
                    display: inline-flex;
                    align-items: center;
                    gap: 6px;
                    padding: 6px 10px;
                    background: #fff;
                    border: 1px solid #ebd9a1;
                    border-radius: 6px;
                    font-size: 13px;
                    color: #6b5a1e;
                }

                .booked-periods-list li i {
                    color: #c2471a;
                    font-size: 11px;
                }

                .booked-periods-hint {
                    margin: 0;
                    font-size: 12px;
                    color: #8a7a3a;
                }

                /* Date Conflict Warning */
                .date-conflict-warning {
                    margin-top: 12px;
                    padding: 12px 14px;
                    background: #fef2f2;
                    border: 1px solid #fecaca;
                    border-radius: 8px;
                    display: flex;
                    align-items: center;
                    gap: 10px;
                    color: #b91c1c;
                    font-size: 13px;
                    font-weight: 600;
                }

                .date-conflict-warning i {
                    font-size: 16px;
                    flex-shrink: 0;
                }

                /* Image Upload Wrapper */
                .image-upload-wrapper {
                    position: relative;
                }

                .upload-hint {
                    position: absolute;
                    top: 0;
                    left: 0;
                    right: 0;
                    bottom: 0;
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                    justify-content: center;
                    gap: 8px;
                    pointer-events: none;
                    color: #8fa498;
                    font-size: 13px;
                    opacity: 0;
                    transition: opacity 0.2s;
                }

                .image-upload-wrapper input[type="file"]:not(:valid) ~ .upload-hint {
                    opacity: 1;
                }

                /* Material Form Preview */
                .material-form-preview .preview-header {
                    display: flex;
                    align-items: center;
                    gap: 8px;
                    margin-bottom: 12px;
                    font-weight: 700;
                    color: #345747;
                    font-size: 14px;
                }

                .material-form-preview .preview-hint {
                    margin: 10px 0 0;
                    font-size: 12px;
                    color: #6b7c72;
                }

                /* Location Lock Note Enhanced */
                .location-lock-note {
                    display: flex;
                    align-items: flex-start;
                    gap: 12px;
                }

                .location-lock-note > i {
                    font-size: 20px;
                    color: #1f8a4c;
                    margin-top: 2px;
                }

                .location-lock-note p {
                    margin: 4px 0 0;
                    font-size: 13px;
                }

                /* Responsive Adjustments */
                @media (max-width: 991px) {
                    .kpi-grid-4 {
                        grid-template-columns: repeat(2, 1fr);
                    }

                    .severity-radio-wrapper {
                        grid-template-columns: 1fr;
                    }

                    .panne-grid, .location-grid {
                        grid-template-columns: 1fr;
                    }
                }

                @media (max-width: 576px) {
                    .kpi-grid-4 {
                        grid-template-columns: 1fr;
                    }

                    .date-range {
                        flex-direction: column;
                        gap: 8px;
                    }

                    .date-arrow {
                        transform: rotate(90deg);
                    }
                }

                /* 3D Scene Styles */
                #bg {
                    position: fixed;
                    top: 0;
                    left: 0;
                    width: 100%;
                    height: 100%;
                    z-index: 1;
                    pointer-events: none;
                }

                /* Only let canvas capture events in 3D mode (non-static) */
                body.farm-3d-mode:not(.static-marketplace) #bg {
                    pointer-events: auto;
                }

                /* Allow UI elements to be clickable above the canvas */
                .ui, .card, .module-head, .kpi-grid, .marketplace-grid, 
                .market-card, button, a, input, select, textarea, 
                .sidebar, nav, header, footer, .modal, .alert,
                [role="button"], [onclick], .actions, .owner-actions,
                .search-sort-bar, .location-grid, .location-card,
                .panne-grid, .panne-card, .view-toggle-bar {
                    position: relative;
                    z-index: 10;
                    pointer-events: auto;
                }

                .label-layer {
                    position: fixed;
                    top: 0;
                    left: 0;
                    width: 100%;
                    height: 100%;
                    pointer-events: none;
                    z-index: 1;
                }

                .label-layer > div {
                    pointer-events: auto;
                }

                .parcel-card {
                    background: rgba(255, 255, 255, 0.95);
                    border-radius: 12px;
                    padding: 12px 16px;
                    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
                    font-family: 'Poppins', sans-serif;
                    font-size: 13px;
                    color: #1e4a32;
                    backdrop-filter: blur(8px);
                    border: 1px solid rgba(30, 74, 50, 0.1);
                    transition: transform 0.2s ease, box-shadow 0.2s ease;
                }

                .parcel-card:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.2);
                }

                /* Equipment Info Card */
                #equipment-info-card {
                    position: fixed;
                    top: 50%;
                    right: 30px;
                    transform: translateY(-50%) translateX(120%);
                    width: 320px;
                    max-width: calc(100vw - 60px);
                    background: rgba(255, 255, 255, 0.98);
                    border-radius: 16px;
                    padding: 20px;
                    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2), 0 0 0 1px rgba(30, 74, 50, 0.1);
                    font-family: 'Poppins', sans-serif;
                    z-index: 1000;
                    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
                    backdrop-filter: blur(12px);
                }

                #equipment-info-card.visible {
                    transform: translateY(-50%) translateX(0);
                }

                #equipment-info-card .close-btn {
                    position: absolute;
                    top: 12px;
                    right: 12px;
                    width: 28px;
                    height: 28px;
                    border: none;
                    background: rgba(0, 0, 0, 0.05);
                    border-radius: 50%;
                    font-size: 18px;
                    color: #666;
                    cursor: pointer;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    transition: all 0.2s;
                }

                #equipment-info-card .close-btn:hover {
                    background: rgba(0, 0, 0, 0.1);
                    color: #333;
                }

                #equipment-info-card .eq-status {
                    display: inline-block;
                    padding: 4px 12px;
                    border-radius: 20px;
                    font-size: 12px;
                    font-weight: 600;
                    text-transform: uppercase;
                    letter-spacing: 0.5px;
                    margin-bottom: 12px;
                }

                #equipment-info-card .eq-status.available {
                    background: #dcfce7;
                    color: #166534;
                }

                #equipment-info-card .eq-status.rented {
                    background: #fef3c7;
                    color: #92400e;
                }

                #equipment-info-card .eq-status.down {
                    background: #fee2e2;
                    color: #991b1b;
                }

                #equipment-info-card .eq-name {
                    font-size: 1.25rem;
                    font-weight: 700;
                    color: #1e4a32;
                    margin: 0 0 4px 0;
                    line-height: 1.3;
                }

                #equipment-info-card .eq-type {
                    font-size: 0.9rem;
                    color: #16a34a;
                    margin: 0 0 12px 0;
                    font-weight: 500;
                }

                #equipment-info-card .eq-desc {
                    font-size: 0.85rem;
                    color: #555;
                    margin: 0 0 16px 0;
                    line-height: 1.5;
                }

                #equipment-info-card .eq-price {
                    background: linear-gradient(135deg, #f0fdf4, #dcfce7);
                    padding: 12px 16px;
                    border-radius: 12px;
                    margin-bottom: 12px;
                    display: flex;
                    align-items: baseline;
                    gap: 6px;
                }

                #equipment-info-card .price-value {
                    font-size: 1.5rem;
                    font-weight: 700;
                    color: #166534;
                }

                #equipment-info-card .price-unit {
                    font-size: 0.85rem;
                    color: #15803d;
                }

                #equipment-info-card .eq-owner {
                    font-size: 0.85rem;
                    color: #666;
                    margin: 0 0 16px 0;
                    display: flex;
                    align-items: center;
                    gap: 8px;
                }

                #equipment-info-card .eq-owner i {
                    color: #16a34a;
                }

                #equipment-info-card .eq-actions {
                    display: flex;
                    gap: 10px;
                }

                #equipment-info-card .btn {
                    flex: 1;
                    padding: 10px 16px;
                    border-radius: 10px;
                    font-size: 0.85rem;
                    font-weight: 600;
                    text-decoration: none;
                    text-align: center;
                    transition: all 0.2s;
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    gap: 6px;
                }

                #equipment-info-card .btn-view {
                    background: #f3f4f6;
                    color: #374151;
                }

                #equipment-info-card .btn-view:hover {
                    background: #e5e7eb;
                }

                #equipment-info-card .btn-rent {
                    background: linear-gradient(135deg, #16a34a, #15803d);
                    color: white;
                }

                #equipment-info-card .btn-rent:hover {
                    background: linear-gradient(135deg, #15803d, #166534);
                    transform: translateY(-1px);
                }

                .reveal-text .char {
                    display: inline-block;
                }

                .space-card {
                    transform-style: preserve-3d;
                }

                .parallax {
                    will-change: transform;
                }

                .ui {
                    position: relative;
                    z-index: 10;
                }

                .hero, .info {
                    position: relative;
                }

                /* Make page content semi-transparent to show 3D scene */
                body {
                    background: transparent !important;
                }
                
                .wrapper {
                    background: transparent !important;
                    position: relative;
                    z-index: 5;
                }
                
                .wrapper > * {
                    position: relative;
                    z-index: 5;
                }

                /* Semi-transparent cards so 3D shows through gaps */
                .card, .market-card, .kpi-card, .location-card {
                    background: rgba(255, 255, 255, 0.95) !important;
                    backdrop-filter: blur(8px);
                }
                
                .module-head {
                    background: rgba(255, 255, 255, 0.92) !important;
                    backdrop-filter: blur(10px);
                }
                
                /* Header semi-transparent in 3D mode only */
                body.farm-3d-mode .header-style-2 {
                    background: rgba(255, 255, 255, 0.95) !important;
                    backdrop-filter: blur(12px);
                }
                
                /* Sidebar semi-transparent */
                .materials-workspace {
                    background: rgba(255, 255, 255, 0.92) !important;
                    backdrop-filter: blur(10px);
                }

                /* ========================================
                   3D FARM MARKETPLACE STYLES
                ======================================== */
                
                /* Compact floating header with integrated stats */
                .farm-3d-header {
                    position: fixed !important;
                    top: 84px;
                    left: 50%;
                    transform: translateX(-50%);
                    z-index: 100;
                    background: rgba(255, 255, 255, 0.96) !important;
                    backdrop-filter: blur(24px);
                    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.15);
                    border-radius: 24px;
                    padding: 16px 28px 12px !important;
                    max-width: 580px;
                    width: auto;
                    margin: 0;
                    transition: box-shadow 0.3s ease, border-radius 0.3s ease;
                    cursor: grab;
                    user-select: none;
                }

                .farm-3d-header.is-dragging {
                    cursor: grabbing;
                    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.25);
                    opacity: 0.95;
                }

                .farm-3d-header.scrolled {
                    top: 76px;
                    padding: 10px 24px 8px !important;
                    max-width: 500px;
                    border-radius: 18px;
                }

                .header-top {
                    display: flex;
                    align-items: center;
                    justify-content: space-between;
                    gap: 16px;
                    margin-bottom: 12px;
                }

                .header-title {
                    display: flex;
                    align-items: center;
                    gap: 10px;
                }

                .header-title h1 {
                    font-size: 1.4rem;
                    font-weight: 700;
                    color: #1a1a1a;
                    margin: 0;
                }

                .farm-3d-header.scrolled .header-title h1 {
                    font-size: 1.1rem;
                }

                .header-icon {
                    width: 36px;
                    height: 36px;
                    background: linear-gradient(135deg, #2d5a27, #4a8c3f);
                    border-radius: 10px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    color: white;
                    font-size: 1rem;
                }

                .farm-3d-header.scrolled .header-icon {
                    width: 30px;
                    height: 30px;
                    font-size: 0.85rem;
                }

                .header-btn {
                    display: inline-flex;
                    align-items: center;
                    gap: 6px;
                    background: linear-gradient(135deg, #2d5a27, #3d7a33);
                    color: white;
                    padding: 8px 16px;
                    border-radius: 12px;
                    font-size: 0.85rem;
                    font-weight: 600;
                    text-decoration: none;
                    transition: all 0.2s ease;
                    box-shadow: 0 2px 8px rgba(45, 90, 39, 0.3);
                }

                .header-btn:hover {
                    transform: translateY(-1px);
                    box-shadow: 0 4px 12px rgba(45, 90, 39, 0.4);
                    background: linear-gradient(135deg, #3d7a33, #4a8c3f);
                }

                .farm-3d-header.scrolled .header-btn {
                    padding: 6px 12px;
                    font-size: 0.8rem;
                }

                /* Inline stats row */
                .header-stats {
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    gap: 12px;
                    padding: 10px 16px;
                    background: rgba(45, 90, 39, 0.06);
                    border-radius: 14px;
                    margin-bottom: 10px;
                }

                .farm-3d-header.scrolled .header-stats {
                    padding: 6px 12px;
                    gap: 10px;
                }

                .stat-item {
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                    min-width: 55px;
                }

                .stat-value {
                    font-size: 1.3rem;
                    font-weight: 700;
                    color: #1a1a1a;
                    line-height: 1;
                }

                .farm-3d-header.scrolled .stat-value {
                    font-size: 1.1rem;
                }

                .stat-label {
                    font-size: 0.65rem;
                    color: #666;
                    text-transform: uppercase;
                    letter-spacing: 0.5px;
                    margin-top: 2px;
                }

                .stat-item.available .stat-value { color: #2d5a27; }
                .stat-item.rented .stat-value { color: #d97706; }
                .stat-item.panne .stat-value { color: #dc2626; }

                .stat-divider {
                    width: 1px;
                    height: 28px;
                    background: rgba(0, 0, 0, 0.1);
                }

                .farm-3d-header.scrolled .stat-divider {
                    height: 22px;
                }

                /* Hint text */
                .header-hint {
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    gap: 6px;
                    font-size: 0.75rem;
                    color: #888;
                    margin: 0;
                }

                .header-hint .divider {
                    color: #ccc;
                    margin: 0 4px;
                }

                .farm-3d-header.scrolled .header-hint {
                    display: none;
                }

                /* Hide marketplace grid on 3D farm page only (cards shown in 3D scene) */
                body.farm-3d-mode:not(.static-marketplace) .marketplace-grid {
                    display: none !important;
                }

                /* Show search toolbar in 3D mode as a floating glass bar */
                body.farm-3d-mode:not(.static-marketplace) #marketplace-toolbar {
                    display: flex !important;
                    position: fixed;
                    bottom: 24px;
                    left: 50%;
                    transform: translateX(-50%);
                    z-index: 110;
                    background: rgba(255, 255, 255, 0.88);
                    backdrop-filter: blur(20px) saturate(1.6);
                    -webkit-backdrop-filter: blur(20px) saturate(1.6);
                    border-radius: 18px;
                    padding: 10px 18px;
                    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.18), 0 0 0 1px rgba(255,255,255,0.3) inset;
                    border: 1px solid rgba(45, 90, 39, 0.15);
                    gap: 10px;
                    max-width: 700px;
                    width: auto;
                    align-items: center;
                    margin-bottom: 0;
                }

                body.farm-3d-mode:not(.static-marketplace) #marketplace-toolbar .search-input {
                    background: rgba(255, 255, 255, 0.6);
                    border-color: rgba(45, 90, 39, 0.15);
                    font-size: 13px;
                    padding: 8px 12px 8px 34px;
                }

                body.farm-3d-mode:not(.static-marketplace) #marketplace-toolbar .sort-select {
                    display: none !important;
                }

                /* When in static mode, hide 3D-only elements */
                body.farm-3d-mode.static-marketplace .farm-3d-header,
                body.farm-3d-mode.static-marketplace .farm-3d-spacer,
                body.farm-3d-mode.static-marketplace .scroll-hint,
                body.farm-3d-mode.static-marketplace #bg,
                body.farm-3d-mode.static-marketplace .menu-toggle-btn {
                    display: none !important;
                }

                body.farm-3d-mode.static-marketplace .marketplace-grid,
                body.farm-3d-mode.static-marketplace #marketplace-toolbar {
                    display: flex !important;
                }

                body.farm-3d-mode.static-marketplace .marketplace-grid {
                    display: grid !important;
                }

                /* View toggle bar */
                .view-toggle-bar {
                    display: flex;
                    align-items: center;
                    justify-content: flex-end;
                    gap: 8px;
                    margin-bottom: 16px;
                }

                body.farm-3d-mode .view-toggle-bar {
                    position: fixed;
                    top: 92px;
                    right: 24px;
                    z-index: 110;
                    margin-bottom: 0;
                }

                .view-toggle-btn {
                    display: inline-flex;
                    align-items: center;
                    gap: 8px;
                    padding: 10px 20px;
                    border-radius: 12px;
                    font-size: 13px;
                    font-weight: 700;
                    cursor: pointer;
                    border: 2px solid #d0ddd5;
                    background: #fff;
                    color: #2b4b39;
                    transition: all 0.25s ease;
                }

                .view-toggle-btn:hover {
                    border-color: #54a56f;
                    background: #f0faf3;
                }

                .view-toggle-btn.is-active {
                    border-color: #1d7a43;
                    background: linear-gradient(135deg, #e6f6ec 0%, #d4eede 100%);
                    color: #115e35;
                    box-shadow: 0 2px 8px rgba(17, 94, 53, 0.15);
                }

                .view-toggle-btn i {
                    font-size: 16px;
                }

                /* Scroll hint indicator */
                .scroll-hint {
                    position: fixed;
                    bottom: 40px;
                    left: 50%;
                    transform: translateX(-50%);
                    z-index: 90;
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                    background: rgba(45, 90, 39, 0.9);
                    color: white;
                    padding: 12px 24px;
                    border-radius: 30px;
                    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.25);
                    animation: bounce 2s infinite;
                    pointer-events: none;
                    transition: opacity 0.5s ease;
                }

                .scroll-hint i {
                    font-size: 1.3rem;
                    margin-bottom: 4px;
                }

                .scroll-hint span {
                    font-size: 0.85rem;
                    font-weight: 500;
                }

                @keyframes bounce {
                    0%, 20%, 50%, 80%, 100% { transform: translateX(-50%) translateY(0); }
                    40% { transform: translateX(-50%) translateY(-8px); }
                    60% { transform: translateX(-50%) translateY(-4px); }
                }

                /* Responsive 3D farm */
                @media (max-width: 768px) {
                    .farm-3d-header {
                        top: 76px;
                        left: 10px;
                        right: 10px;
                        transform: none;
                        max-width: none;
                        padding: 12px 16px 10px !important;
                    }
                    .header-title h1 {
                        font-size: 1.1rem;
                    }
                    .header-stats {
                        gap: 8px;
                        padding: 8px 10px;
                    }
                    .stat-value {
                        font-size: 1.1rem;
                    }
                    .stat-item {
                        min-width: 45px;
                    }
                    .header-btn {
                        padding: 6px 12px;
                        font-size: 0.8rem;
                    }
                }

                /* Collapse side menu on 3D marketplace - toggle with click */
                body.farm-3d-mode .sidebar,
                body.farm-3d-mode .side-menu,
                body.farm-3d-mode .nav-sidebar,
                body.farm-3d-mode aside.card,
                body.farm-3d-mode .workspace-sidebar,
                body:has(.farm-3d-header) .sidebar,
                body:has(.farm-3d-header) .side-menu,
                body:has(.farm-3d-header) .nav-sidebar,
                body:has(.farm-3d-header) aside.card,
                body:has(.farm-3d-header) .workspace-sidebar {
                    position: fixed !important;
                    left: -320px !important;
                    top: 80px;
                    width: 300px;
                    transition: left 0.5s cubic-bezier(0.4, 0, 0.2, 1), transform 0.5s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.5s ease;
                    z-index: 200;
                    max-height: calc(100vh - 100px);
                    overflow-y: auto;
                    border-radius: 0 24px 24px 0 !important;
                    /* 3D glassmorphism with depth */
                    background: linear-gradient(145deg, rgba(255,255,255,0.88) 0%, rgba(240,250,244,0.82) 100%) !important;
                    backdrop-filter: blur(32px) saturate(2) !important;
                    -webkit-backdrop-filter: blur(32px) saturate(2) !important;
                    border: 1px solid rgba(255, 255, 255, 0.5) !important;
                    border-left: none !important;
                    box-shadow:
                        12px 0 48px rgba(0, 0, 0, 0.22),
                        4px 0 16px rgba(45, 90, 39, 0.08),
                        0 0 0 1px rgba(255,255,255,0.35) inset,
                        inset -3px 0 12px rgba(45, 90, 39, 0.04) !important;
                    transform-style: preserve-3d;
                    perspective: 1000px;
                }

                /* 3D sidebar inner styles */
                body.farm-3d-mode .workspace-sidebar h3 {
                    color: #1a4430;
                    font-size: 18px;
                    letter-spacing: 0.5px;
                    text-shadow: 0 2px 4px rgba(255,255,255,0.7);
                    margin-bottom: 4px;
                }

                body.farm-3d-mode .workspace-sidebar p {
                    color: #4a7a5e;
                    font-size: 13px;
                    margin-bottom: 16px;
                }

                body.farm-3d-mode .workspace-link {
                    background: linear-gradient(135deg, rgba(255,255,255,0.65) 0%, rgba(240,250,244,0.5) 100%);
                    border: 1px solid rgba(45, 90, 39, 0.12);
                    backdrop-filter: blur(8px);
                    border-radius: 14px;
                    padding: 12px 16px;
                    margin-bottom: 6px;
                    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                    transform: perspective(600px) rotateY(0deg);
                    transform-origin: left center;
                }

                body.farm-3d-mode .workspace-link:hover {
                    background: linear-gradient(135deg, rgba(238,249,241,0.85) 0%, rgba(220,240,228,0.7) 100%);
                    border-color: rgba(45, 90, 39, 0.28);
                    transform: perspective(600px) rotateY(-2deg) translateX(6px) scale(1.03);
                    box-shadow:
                        6px 6px 20px rgba(45, 90, 39, 0.15),
                        -2px -2px 8px rgba(255, 255, 255, 0.5);
                }

                body.farm-3d-mode .workspace-link.is-active {
                    background: linear-gradient(135deg, rgba(46, 125, 82, 0.22) 0%, rgba(84, 165, 111, 0.28) 100%);
                    border-color: rgba(46, 125, 82, 0.4);
                    box-shadow:
                        0 6px 20px rgba(46, 125, 82, 0.2),
                        inset 0 1px 0 rgba(255,255,255,0.5),
                        inset 0 -1px 0 rgba(0,0,0,0.04);
                    transform: perspective(600px) rotateY(-1deg) translateX(4px);
                }

                body.farm-3d-mode .workspace-link i {
                    filter: drop-shadow(0 1px 2px rgba(45,90,39,0.2));
                }

                /* Menu expanded state */
                body.farm-3d-mode.menu-expanded .sidebar,
                body.farm-3d-mode.menu-expanded .side-menu,
                body.farm-3d-mode.menu-expanded .nav-sidebar,
                body.farm-3d-mode.menu-expanded aside.card,
                body.farm-3d-mode.menu-expanded .workspace-sidebar,
                body:has(.farm-3d-header).menu-expanded .sidebar,
                body:has(.farm-3d-header).menu-expanded aside.card,
                body:has(.farm-3d-header).menu-expanded .workspace-sidebar {
                    left: 0 !important;
                    box-shadow:
                        16px 0 60px rgba(0, 0, 0, 0.25),
                        6px 0 24px rgba(45, 90, 39, 0.1),
                        0 0 0 1px rgba(255,255,255,0.4) inset !important;
                }

                /* Toggle button for menu */
                .menu-toggle-btn {
                    position: fixed;
                    left: 16px;
                    top: 80px;
                    width: 52px;
                    height: 52px;
                    background: linear-gradient(145deg, #2d5a27, #3a7a35);
                    backdrop-filter: blur(20px) saturate(1.8);
                    -webkit-backdrop-filter: blur(20px) saturate(1.8);
                    border-radius: 14px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    font-size: 1.5rem;
                    color: #fff;
                    box-shadow:
                        0 6px 24px rgba(45, 90, 39, 0.35),
                        0 0 0 1px rgba(255,255,255,0.15) inset;
                    cursor: pointer;
                    z-index: 250;
                    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
                    border: none;
                }
                
                .menu-toggle-btn:hover {
                    background: linear-gradient(145deg, #1e4a1a, #2d5a27);
                    color: white;
                    transform: scale(1.08);
                    box-shadow:
                        0 8px 32px rgba(45, 90, 39, 0.45),
                        0 0 0 1px rgba(255,255,255,0.2) inset;
                }
                
                body.menu-expanded .menu-toggle-btn {
                    left: 316px;
                    background: linear-gradient(145deg, #c0392b, #e74c3c);
                    box-shadow: 0 6px 24px rgba(192, 57, 43, 0.35);
                }

                body.menu-expanded .menu-toggle-btn:hover {
                    background: linear-gradient(145deg, #a93226, #c0392b);
                    box-shadow: 0 8px 32px rgba(192, 57, 43, 0.45);
                }
                
                .menu-toggle-btn .icon-open { display: block; }
                .menu-toggle-btn .icon-close { display: none; }
                body.menu-expanded .menu-toggle-btn .icon-open { display: none; }
                body.menu-expanded .menu-toggle-btn .icon-close { display: block; }

                /* Remove old hover behavior and pull tab */
                body.farm-3d-mode .sidebar::after,
                body.farm-3d-mode .side-menu::after,
                body.farm-3d-mode .nav-sidebar::after,
                body.farm-3d-mode aside.card::after,
                body.farm-3d-mode .workspace-sidebar::after,
                body:has(.farm-3d-header) .sidebar::after,
                body:has(.farm-3d-header) .side-menu::after,
                body:has(.farm-3d-header) .nav-sidebar::after,
                body:has(.farm-3d-header) aside.card::after,
                body:has(.farm-3d-header) .workspace-sidebar::after {
                    display: none !important;
                }
            </style>
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body>
        {# 3D Background Canvas for Agriech field scene #}
        <canvas id="bg"></canvas>
        
        {% set currentUserId = app.request.query.get('user_id') %}
        {% if (not currentUserId) and (current_user is defined) and current_user %}
            {% set currentUserId = current_user.id %}
        {% endif %}
        {% set routeName = app.request.attributes.get('_route')|default('') %}
        {% set inMaterialsWorkspace = routeName starts with 'app_materiel_' or routeName starts with 'app_location_' or routeName starts with 'app_panne_' %}
        {% set marketplacePath = path('app_materiel_index', currentUserId ? {'user_id': currentUserId} : {}) %}
        {% set locationsPath = path('app_location_index', currentUserId ? {'user_id': currentUserId} : {}) %}
        {% set pannesPath = path('app_panne_index', currentUserId ? {'user_id': currentUserId} : {}) %}
        {% set createMaterielPath = path('app_materiel_new', currentUserId ? {'user_id': currentUserId} : {}) %}
        {% set switchUserPath = path('app_user_switch_index', {'redirect_to': app.request.requestUri}) %}

        <div class="wrapper home2">
            <header class="header-style-2">
                <nav class="navbar navbar-expand-lg">
                    <a class="navbar-brand custom-brand" href="{{ marketplacePath }}">
                        <span class="brand-mark"><i class="fas fa-leaf"></i></span>
                        <span class="brand-name">AGRINOVA</span>
                    </a>
                    <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                        <i class="fas fa-bars"></i>
                    </button>
                    <div class="collapse navbar-collapse" id="navbarSupportedContent">
                        <ul class="navbar-nav mr-auto agrinova-nav">
                            <li class="nav-item"><a class="nav-link" href="{{ marketplacePath }}">Materials</a></li>
                        </ul>
                        <div class="topbar-right">
                            <label class="sr-only" for="weather">Weather</label>
                            <select id="weather" class="glass-select">
                                <option>Ensoleille</option>
                                <option>Nuageux</option>
                                <option>Pluvieux</option>
                                <option>Neigeux</option>
                            </select>

                            <label class="sr-only" for="timeOfDay">Time of day</label>
                            <select id="timeOfDay" class="glass-select">
                                <option>Matin</option>
                                <option>Coucher de soleil</option>
                                <option>Nuit</option>
                            </select>

                            <label class="sr-only" for="lang">Language</label>
                            <select id="lang" class="glass-select">
                                <option>Francais</option>
                                <option>English</option>
                                <option>Arabic</option>
                            </select>

                            <label class="sr-only" for="currency">Currency</label>
                            <select id="currency" class="glass-select">
                                <option>DT</option>
                                <option>USD</option>
                                <option>EUR</option>
                                <option>GBP</option>
                                <option>JPY</option>
                            </select>

                            <button class="glass-btn" type="button">ChatBot</button>

                            <div class="user-chip">
                                <div class="user-avatar">
                                    <img src="/logo.png" alt="User avatar" />
                                </div>
                                <div class="user-meta">
                                    <span class="user-name">Saidi Ben</span>
                                    <span class="user-email">saidi@agrinova.tn</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </nav>
            </header>

            <section class="inner-header wf100 agrinova-hero">
                <div class="container">
                    <h1>Agrinova Management</h1>
                    <p class="app-subtitle">Operational workspace for materiel, users, rentals, and maintenance incidents.</p>
                </div>
            </section>

            <section class="app-content wf100">
                <div class="container">
                    {% for label, messages in app.flashes %}
                        {% for message in messages %}
                            <div class="alert alert-{{ label }}">{{ message }}</div>
                        {% endfor %}
                    {% endfor %}

                    {% set pageBody %}{% block body %}{% endblock %}{% endset %}

                    {% if inMaterialsWorkspace %}
                        <div class="workspace-layout">
                            <aside class="workspace-sidebar">
                                <h3>Materials Workspace</h3>
                                <p>Persistent navigation for marketplace operations.</p>
                                <nav class="workspace-menu" aria-label="Materials side menu">
                                    <a class="workspace-link {{ routeName starts with 'app_materiel_' ? 'is-active' : '' }}" href="{{ marketplacePath }}">
                                        <i class="fas fa-store"></i>
                                        <span>Marketplace</span>
                                    </a>
                                    <a class="workspace-link {{ routeName starts with 'app_location_' ? 'is-active' : '' }}" href="{{ locationsPath }}">
                                        <i class="far fa-calendar-alt"></i>
                                        <span>Locations</span>
                                    </a>
                                    <a class="workspace-link {{ routeName starts with 'app_panne_' ? 'is-active' : '' }}" href="{{ pannesPath }}">
                                        <i class="fas fa-tools"></i>
                                        <span>Pannes</span>
                                    </a>
                                    <a class="workspace-link" href="{{ createMaterielPath }}">
                                        <i class="fas fa-plus-circle"></i>
                                        <span>Create Materiel</span>
                                    </a>
                                    <a class="workspace-link" href="{{ switchUserPath }}">
                                        <i class="fas fa-users"></i>
                                        <span>Switch User</span>
                                    </a>
                                </nav>
                            </aside>
                            <div class="workspace-content">{{ pageBody }}</div>
                        </div>
                    {% else %}
                        {{ pageBody }}
                    {% endif %}
                </div>
            </section>

            <footer class="footer">
                <div class="footer-copyr wf100">
                    <div class="container">
                        <div class="row">
                            <div class="col-md-4 col-sm-4">
                                <p class="brand-foot">AGRINOVA</p>
                            </div>
                            <div class="col-md-8 col-sm-8">
                                <p>Designed for Agrinova operations using a customized template shell.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </footer>
        </div>

        {% block javascripts %}
            <script src="{{ asset('ecova/js/jquery-3.3.1.min.js') }}"></script>
            <script src="{{ asset('ecova/js/jquery-migrate-1.4.1.min.js') }}"></script>
            <script src="{{ asset('ecova/js/popper.min.js') }}"></script>
            <script src="{{ asset('ecova/js/bootstrap.min.js') }}"></script>
            <script src="{{ asset('ecova/js/owl.carousel.min.js') }}"></script>
            <script src="{{ asset('ecova/js/jquery.prettyPhoto.js') }}"></script>
            <script src="{{ asset('ecova/js/isotope.min.js') }}"></script>
            {# GSAP for 3D scene animations #}
            <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
            <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
            {# Three.js 3D scene - loaded as module with cache bust #}
            <script type="module" src="{{ asset('ecova/js/custom.js') }}?v={{ "now"|date('U') }}"></script>
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </body>
</html>
