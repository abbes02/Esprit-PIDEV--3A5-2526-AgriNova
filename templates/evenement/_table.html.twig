{% for evenement in evenements %}
    <tr>
        <td>{{ evenement.formation.titre }}</td>
        <td>{{ evenement.lieu }}</td>
        <td>{{ evenement.type }}</td>
        <td>{{ evenement.dateDebut|date('d/m/Y H:i') }}</td>
        <td>{{ evenement.dateFin|date('d/m/Y H:i') }}</td>
        <td>{{ evenement.capaciteMax }}</td>
        <td>{{ evenement.nombreInscrits }}</td>
        <td><span class="badge-soft">{{ evenement.statut }}</span></td>
        <td>
            <div class="stack-sm">
                <a href="{{ path('evenement_show', { id: evenement.id }) }}" class="button-secondary">Voir</a>
                <a href="{{ path('evenement_edit', { id: evenement.id }) }}" class="button-primary">Modifier</a>
                <form method="post" action="{{ path('evenement_delete', { id: evenement.id }) }}" onsubmit="return confirm('Supprimer cet evenement ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ evenement.id) }}">
                    <button class="button-success" type="submit">Supprimer</button>
                </form>
            </div>
        </td>
    </tr>
{% else %}
    <tr>
        <td colspan="9" class="text-center muted py-4">Aucun evenement trouve.</td>
    </tr>
{% endfor %}
