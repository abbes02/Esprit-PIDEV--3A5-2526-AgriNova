{# ═══════════════════════════════════════════════
   Z-DEPTH SCROLL ENGINE  (no Three.js, pure CSS+JS)
   ═══════════════════════════════════════════════ #}
<script src="{{ asset('libs/gsap.min.js') }}"></script>
<script src="{{ asset('libs/ScrollTrigger.min.js') }}"></script>
<script>
  if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
    gsap.registerPlugin(ScrollTrigger);
  }
</script>
<script>
(function () {
  /* ── Config ──────────────────────────────────────────────────────────────
   * Each card starts at translateZ(-FAR) and travels to translateZ(NEAR).
   * GSAP ScrollTrigger maps scroll progress → Z position.
   * ─────────────────────────────────────────────────────────────────────── */
  const FAR   = -340;   // starting depth (far away)
  const NEAR  =  60;    // ending depth   (slightly past camera)
  const EASE  = 'power2.out';

  /* ── Scroll progress bar ─────────────────────────────────────────────── */
  const progressBar = document.getElementById('scroll-progress');

  window.addEventListener('scroll', () => {
    const max = document.documentElement.scrollHeight - window.innerHeight;
    progressBar.style.width = (window.scrollY / max * 100) + '%';
  }, { passive: true });

  /* ── Lerp helper for smooth manual fallback ──────────────────────────── */
  function lerp(a, b, t) { return a + (b - a) * t; }

  /* ── Core Z-scroll logic ─────────────────────────────────────────────── */
  const cards = document.querySelectorAll('.z-card');
  const feats = document.querySelectorAll('.feat-item');

  if (typeof gsap !== 'undefined') {
    /* ── GSAP path ─────────────────────────────────────────────────────── */

    cards.forEach((card, i) => {
      const section = card.closest('.z-section');

      /* Entrance: card flies from FAR → resting position (translateZ 0) */
      gsap.fromTo(card,
        { translateZ: FAR, scale: 0.7, opacity: 0 },
        {
          translateZ: 0,
          scale: 1,
          opacity: 1,
          ease: EASE,
          scrollTrigger: {
            trigger: section,
            start: 'top 85%',
            end:   'top 20%',
            scrub: 1.4,
          }
        }
      );

      /* Exit: card continues forward past camera (0 → NEAR) and fades */
      gsap.fromTo(card,
        { translateZ: 0, opacity: 1 },
        {
          translateZ: NEAR,
          opacity: 0,
          ease: 'power1.in',
          scrollTrigger: {
            trigger: section,
            start: 'top -10%',
            end:   'top -60%',
            scrub: 1,
          }
        }
      );
    });

    /* ── Parallax on feat-items (staggered Z depth) ─────────────────────── */
    feats.forEach((el, i) => {
      const depth = -80 - (i % 4) * 30;   // each item at a slightly different Z
      gsap.fromTo(el,
        { translateZ: depth, opacity: 0, y: 30 },
        {
          translateZ: 0,
          opacity: 1,
          y: 0,
          ease: EASE,
          scrollTrigger: {
            trigger: el.closest('.z-section'),
            start: 'top 70%',
            end:   'top 10%',
            scrub: 1.8,
          }
        }
      );
    });

  } else {
    /* ── Vanilla fallback (no GSAP) — IntersectionObserver + lerp ──────── */
    let ticking = false;

    function getProgress(el) {
      const rect = el.getBoundingClientRect();
      const vh   = window.innerHeight;
      // 0 = just entered bottom, 1 = top at 20% from top
      return Math.min(1, Math.max(0, (vh - rect.top) / (vh * 0.8)));
    }

    const state = Array.from(cards).map(() => ({ z: FAR, opacity: 0, current: 0 }));

    function tick() {
      cards.forEach((card, i) => {
        const target = getProgress(card.closest('.z-section'));
        state[i].current = lerp(state[i].current, target, 0.08);
        const z   = lerp(FAR, 0, state[i].current);
        const sc  = lerp(0.7, 1, state[i].current);
        const op  = Math.min(1, state[i].current * 2);
        card.style.transform = `translateZ(${z}px) scale(${sc})`;
        card.style.opacity   = op;
      });
      ticking = false;
    }

    window.addEventListener('scroll', () => {
      if (!ticking) { requestAnimationFrame(tick); ticking = true; }
    }, { passive: true });

    tick();
  }

  /* ── Hide scroll hint after first scroll ────────────────────────────── */
  const hint = document.querySelector('.scroll-hint');
  if (hint) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 60) hint.style.opacity = '0';
      else hint.style.opacity = '1';
    }, { passive: true, once: false });
  }

})();
</script>
</body>
</html>
