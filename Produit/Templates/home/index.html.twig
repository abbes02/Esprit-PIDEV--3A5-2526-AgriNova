{% extends 'base.html.twig' %}

{% block title %}Agriech | Smart Agriculture Experience{% endblock %}

{% block stylesheets %}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
        href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap"
        rel="stylesheet"
    />
    <link rel="stylesheet" href="/StyleFront.css?v=20260409-1">
{% endblock %}

{% block javascripts %}
    <script src="/libs/gsap.min.js"></script>
    <script src="/libs/ScrollTrigger.min.js"></script>
    <script type="module" src="/main.js?v=20260409-1"></script>
{% endblock %}

{% block body %}
    <!-- 3D canvas background -->
    <canvas id="bg" aria-hidden="true"></canvas>

    <!-- UI overlay -->
    <main class="ui">
        <header class="topbar">
            <div class="topbar-left">
                <span class="app-name">AGRINOVA</span>
                <span class="time" id="time">--:--</span>
                <span class="temp">24&deg;C</span>
            </div>
            <div class="topbar-right">
                <label class="sr-only" for="weather">Weather</label>
                <select id="weather" class="glass-select">
                    <option>Ensoleill&eacute;</option>
                    <option>Nuageux</option>
                    <option>Pluvieux</option>
                    <option>Neigeux</option>
                </select>

                <label class="sr-only" for="timeOfDay">Time of day</label>
                <select id="timeOfDay" class="glass-select">
                    <option>Matin</option>
                    <option>Coucher de soleil</option>
                    <option>Nuit</option>
                </select>

                <label class="sr-only" for="lang">Language</label>
                <select id="lang" class="glass-select">
                    <option>Fran&ccedil;ais</option>
                    <option>English</option>
                    <option>Arabic</option>
                </select>

                <label class="sr-only" for="currency">Currency</label>
                <select id="currency" class="glass-select">
                    <option>DT</option>
                    <option>USD</option>
                    <option>EUR</option>
                    <option>GBP</option>
                    <option>JPY</option>
                </select>

                <button class="glass-btn" type="button">ChatBot</button>
            <a class="glass-btn primary" href="{{ path('liste_produit_agricole') }}">Login</a>
            </div>
        </header>

        <section class="hero" id="top">
            <div class="hero-content parallax" data-speed="0.4">
                <p class="eyebrow">Bienvenue dans le futur de l'agriculture</p>
                <h1 class="reveal-text">Agriech</h1>
                <p class="subtitle reveal-text">
                    Exp&eacute;rience d'agriculture intelligente
                </p>
            <a class="cta" href="{{ path('liste_produit_agricole') }}">Entrer sur la plateforme</a>
            </div>
            <div class="scroll-hint">D&eacute;filez pour explorer</div>
        </section>

        <section class="info" id="about">
            <div class="info-stack">
                <div class="info-card parallax space-card" data-speed="0.2">
                    <h2 class="reveal-text">C&rsquo;EST QUOI AGRIECH ?</h2>
                    <p class="reveal-text">
                        Suivi intelligent des parcelles
                        Analyse des cultures
                        Gestion agricole moderne
                    </p>
                    <button class="cta small" type="button">Voir</button>
                </div>
                <div class="info-card parallax space-card" data-speed="0.25">
                    <h2 class="reveal-text">FONCTIONNALIT&Eacute;S</h2>
                    <p class="reveal-text">
                        &#127807; Gestion des parcelles
                        &#128167; Suivi irrigation
                        &#128202; Statistiques
                        &#128205; Localisation terrain
                    </p>
                </div>
                <div class="info-card parallax space-card" data-speed="0.3">
                    <h2 class="reveal-text">Sustainable Decisions</h2>
                    <p class="reveal-text">
                        Make smarter choices with streamlined monitoring and adaptive
                        field management.
                    </p>
                    <p class="note">Optional: add subtle ambient farm sounds for depth.</p>
                </div>
            </div>
        </section>

        <footer class="footer">
            <span>&copy; 2026 Agriech. All rights reserved.</span>
        </footer>

        <div class="interaction-hint">Scroll to explore &middot; Hover parcels</div>
    </main>
{% endblock %}
