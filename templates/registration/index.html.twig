{% extends 'base.html.twig' %}

{% block title %}Creation de compte | AgriNova{% endblock %}
{% block meta_description %}Creer un compte AgriNova.{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="/styles/agriculteur.css">
{% endblock %}

{% block javascripts %}
    <script src="/libs/gsap/gsap.min.js"></script>
    <script src="/libs/gsap/ScrollTrigger.min.js"></script>
    <script type="module" src="/scripts/agriculteur-scene.js"></script>
{% endblock %}

{% block body %}
    <canvas id="bg" aria-hidden="true"></canvas>

    <main class="agri-page">
        <section class="auth-shell ui">
            <aside class="auth-box glass parallax" data-speed="0.12">
                <div>
                    <p class="eyebrow">AgriNova</p>
                    <h1 class="reveal-text">Creation de compte</h1>
                    <p class="hero-text">
                        Creez votre compte depuis un formulaire unique, sans barre de navigation.
                    </p>
                </div>

                {{ form_start(form, {'attr': {'class': 'auth-stack', 'novalidate': 'novalidate'}}) }}
                    {{ form_errors(form) }}

                    <div class="auth-row">
                        <div>
                            {{ form_label(form.nom) }}
                            {{ form_widget(form.nom, {'attr': {'id': form.nom.vars.id}}) }}
                            {{ form_errors(form.nom) }}
                        </div>

                        <div>
                            {{ form_label(form.prenom) }}
                            {{ form_widget(form.prenom, {'attr': {'id': form.prenom.vars.id}}) }}
                            {{ form_errors(form.prenom) }}
                        </div>
                    </div>

                    <div>
                        {{ form_label(form.email) }}
                        {{ form_widget(form.email, {'attr': {'id': form.email.vars.id}}) }}
                        {{ form_errors(form.email) }}
                    </div>

                    <div class="auth-row">
                        <div>
                            {{ form_label(form.telephone) }}
                            {{ form_widget(form.telephone, {'attr': {'id': form.telephone.vars.id, 'placeholder': '21612345678'}}) }}
                            {{ form_errors(form.telephone) }}
                        </div>

                        <div>
                            {{ form_label(form.role) }}
                            {{ form_widget(form.role, {'attr': {'id': form.role.vars.id}}) }}
                            {{ form_errors(form.role) }}
                        </div>
                    </div>

                    <div>
                        {{ form_label(form.adresse) }}
                        {{ form_widget(form.adresse, {'attr': {'id': form.adresse.vars.id}}) }}
                        {{ form_errors(form.adresse) }}
                    </div>

                    <div class="auth-row">
                        <div>
                            {{ form_label(form.motDePasse.first) }}
                            {{ form_widget(form.motDePasse.first, {'attr': {'id': form.motDePasse.first.vars.id}}) }}
                            {{ form_errors(form.motDePasse.first) }}
                        </div>

                        <div>
                            {{ form_label(form.motDePasse.second) }}
                            {{ form_widget(form.motDePasse.second, {'attr': {'id': form.motDePasse.second.vars.id}}) }}
                            {{ form_errors(form.motDePasse.second) }}
                        </div>
                    </div>

                    <button type="submit" class="primary-action">Creer mon compte</button>
                {{ form_end(form) }}

                <p class="helper-text">
                    Vous avez deja un compte ?
                    <a class="link" href="/login">Se connecter</a>
                </p>
            </aside>
        </section>
    </main>
{% endblock %}
