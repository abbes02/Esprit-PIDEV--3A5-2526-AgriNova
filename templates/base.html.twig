                    border-radius: 14px;
                    box-shadow: 0 4px 14px rgba(14, 79, 45, 0.06);
                    flex-wrap: wrap;
                }

                .search-sort-bar .search-input-wrap {
                    flex: 1 1 220px;
                    position: relative;
                }

                .search-sort-bar .search-input-wrap i {
                    position: absolute;
                    left: 14px;
                    top: 50%;
                    transform: translateY(-50%);
                    color: #8fa498;
                    font-size: 14px;
                    pointer-events: none;
                }

                .search-sort-bar .search-input {
                    width: 100%;
