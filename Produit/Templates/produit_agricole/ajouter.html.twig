{% extends 'base.html.twig' %}

{% block body_class %}liste-produit-page ajouter-form-page{% endblock %}

{% block title %}Ajouter Produit Agricole{% endblock %}

{% set type = 'agricole' %}

{% block body %}
<canvas id="bg" aria-hidden="true"></canvas>

<header class="topbar">
    <div class="topbar-left">
        <span class="app-name">AGRINOVA</span>
        <span class="time" id="time">--:--</span>
        <span class="temp">24&deg;C</span>
    </div>
    <div class="topbar-right">
        <label class="sr-only" for="weather">Weather</label>
        <select id="weather" class="glass-select">
            <option>Ensoleill&eacute;</option>
            <option>Nuageux</option>
            <option>Pluvieux</option>
            <option>Neigeux</option>
        </select>

        <label class="sr-only" for="timeOfDay">Time of day</label>
        <select id="timeOfDay" class="glass-select">
            <option>Matin</option>
            <option>Coucher de soleil</option>
            <option>Nuit</option>
        </select>

        <label class="sr-only" for="lang">Language</label>
        <select id="lang" class="glass-select">
            <option>Fran&ccedil;ais</option>
            <option>English</option>
            <option>Arabic</option>
        </select>

        <label class="sr-only" for="currency">Currency</label>
        <select id="currency" class="glass-select">
            <option>DT</option>
            <option>USD</option>
            <option>EUR</option>
            <option>GBP</option>
            <option>JPY</option>
        </select>

        <button class="glass-btn" type="button">ChatBot</button>
        <a class="glass-btn primary" href="{{ path('liste_produit_agricole') }}">Retour</a>
    </div>
</header>

<aside class="sidebar">
    <div class="sidebar-logo-container">
        <div class="sidebar-logo-circle">
            <a href="{{ path('app_home') }}">
                <img src="/logo.png" alt="AGRINOVA logo" />
            </a>
        </div>
        <div class="sidebar-logo-text">
            <div class="sidebar-logo-label">AGRINOVA</div>
            <div class="sidebar-subtitle">L'EXCELLENCE RURALE</div>
        </div>
    </div>

    <div class="sidebar-separator"></div>

    <nav class="sidebar-buttons">
        <a class="sidebar-button" href="#">
            <svg class="sidebar-icon" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M3 3h8v8H3V3zm10 0h8v8h-8V3zM3 13h8v8H3v-8zm10 0h8v8h-8v-8z"/>
            </svg>
            Parcelles
        </a>
        <a class="sidebar-button" href="{{ path('produit_iot_list') }}">
            <svg class="sidebar-icon" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2l7 4v6c0 5-3.8 9.7-7 10-3.2-.3-7-5-7-10V6l7-4z"/>
            </svg>
            Produits IOT
        </a>
        <a class="sidebar-button active" href="{{ path('liste_produit_agricole') }}">
            <svg class="sidebar-icon" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 3C7 3 4 7 4 11c0 4 3 7 8 10 5-3 8-6 8-10 0-4-3-8-8-8z"/>
            </svg>
            Produits Agricole
        </a>
        <a class="sidebar-button" href="#">
            <svg class="sidebar-icon" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M4 7h16v10H4V7zm2-4h12v2H6V3zm2 14h8v2H8v-2z"/>
            </svg>
            Materiels
        </a>
        <a class="sidebar-button" href="#">
            <svg class="sidebar-icon" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 3l9 4-9 4-9-4 9-4zm-7 6v6l7 3 7-3V9l-7 3-7-3z"/>
            </svg>
            Formations
        </a>
        <a class="sidebar-button" href="#">
            <svg class="sidebar-icon" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M19 4h-1V2h-2v2H8V2H6v2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 16H5V10h14v10zM7 12h5v5H7z"/>
            </svg>
            Evenements
        </a>
        <a class="sidebar-button" href="#">
            <svg class="sidebar-icon" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M3 6h11v8H3V6zm12 2h3l3 3v3h-6V8zM6 18a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm10 0a2 2 0 1 0 0 4 2 0 0 0 0-4z"/>
            </svg>
            Livraison
        </a>
    </nav>

    <div class="sidebar-footer">
        <a class="sidebar-button logout" href="#">Deconnexion</a>
    </div>
</aside>

<main class="ui">
    <div class="login-wrap product-wrap" style="margin-top: 6rem;">
        <div class="login-card product-card-shell agri-form-shell">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <h1 class="mb-0">Ajouter un produit agricole</h1>
                <a class="glass-btn" href="{{ path('liste_produit_agricole') }}">Retour</a>
            </div>

            {{ form_start(form, {'attr': {'class': 'ajouter-form', 'id': 'agri-form'}}) }}
                <div class="ajouter-grid">
                    <div class="ajouter-upload">
                        <div class="upload-box" id="agri-dropzone">
                            <p>Glissez-déposez une image ici</p>
                            <button type="button" class="upload-btn" id="agri-image-btn">Parcourir</button>
                            <span class="upload-hint" id="agri-image-hint">PNG, JPG, WEBP</span>
                            <img id="agri-image-preview" alt="Aperçu" hidden style="max-width:100%; margin-top:0.75rem; border-radius:12px;" />
                        </div>
                        <input id="agri-image-input" type="file" accept="image/*" hidden />
                        {{ form_widget(form.image, {'attr': {'class': 'glass-input', 'id': 'produit_agricole_image', 'hidden': true}}) }}
                    </div>
                    <div class="ajouter-fields">
                        <div class="field-block">
                            {{ form_label(form.nom, 'Nom du produit') }}
                            {{ form_widget(form.nom, {'attr': {'class': 'glass-input', 'placeholder': 'ex: Blé dur Premium'}}) }}
                            <small class="field-error" id="help-nom">Commence par majuscule +2 caractères (obligatoire)</small>
                        </div>
                        <div class="field-block">
                            {{ form_label(form.ref, 'Référence') }}
                            {{ form_widget(form.ref, {'attr': {'class': 'glass-input', 'placeholder': 'REF-001'}}) }}
                            <small class="field-hint" id="help-ref">La référence doit être unique pour chaque produit (obligatoire)</small>
                        </div>
                        <div class="field-row">
                            <div class="field-block">
                                {{ form_label(form.categorieAgricole, 'Catégorie') }}
                                {{ form_widget(form.categorieAgricole, {'attr': {'class': 'glass-input'}}) }}
                                <small class="field-hint" id="help-cat"></small>
                            </div>
                            <div class="field-block">
                                {{ form_label(form.prix, 'Prix (TND)') }}
                                {{ form_widget(form.prix, {'attr': {'class': 'glass-input'}}) }}
                                <small class="field-hint" id="help-prix"></small>
                            </div>
                        </div>
                        <div class="field-row">
                            <div class="field-block">
                                {{ form_label(form.quantite, 'Stock Initial') }}
                                {{ form_widget(form.quantite, {'attr': {'class': 'glass-input'}}) }}
                                <small class="field-hint" id="help-stock"></small>
                            </div>
                            <div class="field-block">
                                <div class="d-flex align-items-center justify-content-between">
                                    {{ form_label(form.dateExpiration, 'Date d\'expiration') }}
                                    <button class="glass-btn" type="button" id="date-open-btn">📅</button>
                                </div>
                                {{ form_widget(form.dateExpiration, {'attr': {'class': 'glass-input date-input'}}) }}
                                <small class="field-hint" id="help-date"></small>
                            </div>
                        </div>
                        <div class="field-block full">
                            {{ form_label(form.description, 'Description et notes de culture') }}
                            {{ form_widget(form.description, {'attr': {'class': 'glass-input', 'rows': 5, 'placeholder': 'Notes de culture, conditions, conseils...'}}) }}
                        </div>
                    </div>
                </div>

                <div class="ajouter-actions">
                    <button class="ajouter-submit" type="submit" id="agri-submit" disabled>Ajouter le produit</button>
                    <a class="ajouter-cancel" href="{{ path('liste_produit_agricole') }}">Annuler</a>
                    <span id="agri-submit-hint" class="field-hint"></span>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</main>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {% if type is defined and type == 'agricole' %}
        <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script>
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                const imageBtn = document.getElementById('agri-image-btn');
                const imageInput = document.getElementById('agri-image-input');
                const imagePreview = document.getElementById('agri-image-preview');
                const imageField = document.getElementById('produit_agricole_image');
                const dropzone = document.getElementById('agri-dropzone');
                const imageHint = document.getElementById('agri-image-hint');
                const agriForm = document.getElementById('agri-form');
                const agriSubmit = document.getElementById('agri-submit');
                const refInput = document.getElementById('produit_agricole_ref');
                const refHint = document.getElementById('help-ref');
                const expirationInput = document.getElementById('produit_agricole_dateExpiration');
                const dateOpenBtn = document.getElementById('date-open-btn');
                let refAvailable = null;
                let refTimer = null;

                const handleFile = (file) => {
                    if (!file) {
                        return;
                    }
                    if (imageField) {
                        imageField.value = `C:\\Users\\saidi\\Downloads\\${file.name}`;
                    }
                    const reader = new FileReader();
                    reader.onload = (e) => {
                        if (imagePreview) {
                            imagePreview.src = e.target.result;
                            imagePreview.hidden = false;
                        }
                        if (imageHint) {
                            imageHint.textContent = 'Image chargee';
                            imageHint.classList.add('is-ok');
                        }
                    };
                    reader.readAsDataURL(file);
                };

                if (imageBtn && imageInput) {
                    imageBtn.addEventListener('click', () => imageInput.click());
                    imageInput.addEventListener('change', (event) => {
                        const file = event.target.files && event.target.files[0];
                        handleFile(file);
                    });
                }

                if (dropzone) {
                    const onDragOver = (event) => {
                        event.preventDefault();
                        dropzone.classList.add('is-dragover');
                    };
                    const onDragLeave = () => {
                        dropzone.classList.remove('is-dragover');
                    };
                    const onDrop = (event) => {
                        event.preventDefault();
                        dropzone.classList.remove('is-dragover');
                        const file = event.dataTransfer && event.dataTransfer.files && event.dataTransfer.files[0];
                        handleFile(file);
                    };
                    dropzone.addEventListener('dragover', onDragOver);
                    dropzone.addEventListener('dragleave', onDragLeave);
                    dropzone.addEventListener('drop', onDrop);
                }

                if (agriForm && agriSubmit) {
                    agriForm.querySelectorAll('input[type="hidden"][required]').forEach((el) => {
                        el.required = false;
                    });
                    ['produit_agricole_image', 'produit_agricole_description'].forEach((id) => {
                        const field = document.getElementById(id);
                        if (field) {
                            field.required = false;
                        }
                    });

                    const updateSubmitState = () => {
                        const requiredFields = agriForm.querySelectorAll('input[required], select[required], textarea[required]');
                        const missing = [];
                        requiredFields.forEach((field) => {
                            if (field.disabled || field.type === 'hidden') {
                                return;
                            }
                            if (field.type === 'checkbox' || field.type === 'radio') {
                                if (!field.checked) {
                                    missing.push(field);
                                }
                                return;
                            }
                            const value = (field.value || '').trim();
                            if (value === '') {
                                missing.push(field);
                                return;
                            }
                            if (field.id === 'produit_agricole_nom') {
                                const nameOk = /^[A-Z].{2,}$/.test(value);
                                if (!nameOk) {
                                    missing.push(field);
                                }
                            }
                            if (field.id === 'produit_agricole_dateExpiration') {
                                const today = new Date();
                                today.setHours(0, 0, 0, 0);
                                const selected = new Date(value);
                                if (!(selected > today)) {
                                    missing.push(field);
                                }
                            }
                        });

                        if (refInput && refInput.value.trim() !== '' && refAvailable === false) {
                            missing.push(refInput);
                        }

                        const isValid = missing.length === 0;
                        agriSubmit.disabled = !isValid;
                        agriSubmit.setAttribute('aria-disabled', String(!isValid));

                        const hint = document.getElementById('agri-submit-hint');
                        if (hint) {
                            const details = [];
                            const nameField = document.getElementById('produit_agricole_nom');
                            const helpNom = document.getElementById('help-nom');
                            if (nameField && helpNom) {
                                const value = (nameField.value || '').trim();
                                let nameMsg = '';
                                let isOk = false;
                                if (value === '') {
                                    nameMsg = 'Nom obligatoire';
                                } else if (!/^[A-Z]/.test(value)) {
                                    nameMsg = 'Le nom doit commencer par une majuscule';
                                } else if (value.length < 3) {
                                    nameMsg = 'Il faut au moins 3 caracteres';
                                } else {
                                    nameMsg = 'Nom valide';
                                    isOk = true;
                                }

                                if (!isOk) {
                                    details.push(`Nom: ${nameMsg}`);
                                    helpNom.textContent = nameMsg;
                                    helpNom.classList.remove('is-ok');
                                    helpNom.classList.add('is-error');
                                } else {
                                    helpNom.textContent = nameMsg;
                                    helpNom.classList.remove('is-error');
                                    helpNom.classList.add('is-ok');
                                }
                            }
                            const refField = document.getElementById('produit_agricole_ref');
                            const helpRef = document.getElementById('help-ref');
                            if (refField && helpRef) {
                                const value = (refField.value || '').trim();
                                let msg = '';
                                let ok = false;
                                if (value === '') {
                                    msg = 'Reference obligatoire';
                                } else if (refAvailable === null) {
                                    msg = 'Verification en cours...';
                                } else if (refAvailable === false) {
                                    msg = 'Reference deja utilisee';
                                } else {
                                    msg = 'Reference valide';
                                    ok = true;
                                }
                                if (!ok) {
                                    details.push(`Reference: ${msg}`);
                                    helpRef.textContent = msg;
                                    helpRef.classList.remove('is-ok');
                                    helpRef.classList.add('is-error');
                                } else {
                                    helpRef.textContent = msg;
                                    helpRef.classList.remove('is-error');
                                    helpRef.classList.add('is-ok');
                                }
                            }
                            const catField = document.getElementById('produit_agricole_categorieAgricole');
                            const helpCat = document.getElementById('help-cat');
                            if (catField && helpCat) {
                                const value = (catField.value || '').trim();
                                if (!value) {
                                    details.push('Categorie: obligatoire');
                                    helpCat.textContent = 'Categorie obligatoire';
                                    helpCat.classList.remove('is-ok');
                                    helpCat.classList.add('is-error');
                                } else {
                                    helpCat.textContent = 'Categorie valide';
                                    helpCat.classList.remove('is-error');
                                    helpCat.classList.add('is-ok');
                                }
                            }
                            const prixField = document.getElementById('produit_agricole_prix');
                            const helpPrix = document.getElementById('help-prix');
                            if (prixField && helpPrix) {
                                const value = (prixField.value || '').trim();
                                if (!value) {
                                    details.push('Prix: obligatoire');
                                    helpPrix.textContent = 'Prix obligatoire';
                                    helpPrix.classList.remove('is-ok');
                                    helpPrix.classList.add('is-error');
                                } else {
                                    helpPrix.textContent = 'Prix valide';
                                    helpPrix.classList.remove('is-error');
                                    helpPrix.classList.add('is-ok');
                                }
                            }
                            const stockField = document.getElementById('produit_agricole_quantite');
                            const helpStock = document.getElementById('help-stock');
                            if (stockField && helpStock) {
                                const value = (stockField.value || '').trim();
                                if (!value) {
                                    details.push('Stock: obligatoire');
                                    helpStock.textContent = 'Stock obligatoire';
                                    helpStock.classList.remove('is-ok');
                                    helpStock.classList.add('is-error');
                                } else {
                                    helpStock.textContent = 'Stock valide';
                                    helpStock.classList.remove('is-error');
                                    helpStock.classList.add('is-ok');
                                }
                            }
                            const dateField = document.getElementById('produit_agricole_dateExpiration');
                            const helpDate = document.getElementById('help-date');
                            if (dateField && helpDate) {
                                const value = (dateField.value || '').trim();
                                if (value === '') {
                                    details.push('Date expiration: obligatoire');
                                    helpDate.textContent = 'Date expiration obligatoire';
                                    helpDate.classList.remove('is-ok');
                                    helpDate.classList.add('is-error');
                                } else {
                                    const today = new Date();
                                    today.setHours(0, 0, 0, 0);
                                    const selected = new Date(value);
                                    if (!(selected > today)) {
                                        details.push("Date expiration: doit etre superieure a aujourd'hui");
                                        helpDate.textContent = "Date expiration doit etre superieure a aujourd'hui";
                                        helpDate.classList.remove('is-ok');
                                        helpDate.classList.add('is-error');
                                    } else {
                                        helpDate.textContent = 'Date expiration valide';
                                        helpDate.classList.remove('is-error');
                                        helpDate.classList.add('is-ok');
                                    }
                                }
                            }

                            hint.style.opacity = '0';
                            hint.textContent = '';
                        }
                    };

                    agriForm.addEventListener('input', updateSubmitState);
                    agriForm.addEventListener('change', updateSubmitState);
                    agriForm.addEventListener('keyup', updateSubmitState);
                    window.addEventListener('load', updateSubmitState);
                    updateSubmitState();
                    setInterval(updateSubmitState, 800);
                }

                if (refInput && refHint) {
                    const checkRef = async () => {
                        const value = refInput.value.trim();
                        if (value === '') {
                            refAvailable = null;
                            refHint.textContent = '';
                            refHint.classList.remove('is-ok', 'is-error');
                            return;
                        }
                        try {
                            const res = await fetch(`/produit/check-ref?ref=${encodeURIComponent(value)}`);
                            const data = await res.json();
                            refAvailable = data && data.available === true;
                            if (refAvailable) {
                                refHint.textContent = 'Reference disponible.';
                                refHint.classList.add('is-ok');
                                refHint.classList.remove('is-error');
                            } else {
                                refHint.textContent = 'Reference deja utilisee.';
                                refHint.classList.add('is-error');
                                refHint.classList.remove('is-ok');
                            }
                        } catch (e) {
                            refAvailable = null;
                            refHint.textContent = 'Verification impossible.';
                            refHint.classList.add('is-error');
                            refHint.classList.remove('is-ok');
                        }
                    };

                    const scheduleCheck = () => {
                        if (refTimer) {
                            clearTimeout(refTimer);
                        }
                        refTimer = setTimeout(checkRef, 150);
                    };

                    refInput.addEventListener('input', scheduleCheck);
                    refInput.addEventListener('change', scheduleCheck);
                    refInput.addEventListener('blur', checkRef);
                }

                if (expirationInput) {
                    const today = new Date();
                    const yyyy = today.getFullYear();
                    const mm = String(today.getMonth() + 1).padStart(2, '0');
                    const dd = String(today.getDate()).padStart(2, '0');
                    const minDate = `${yyyy}-${mm}-${dd}`;
                    expirationInput.setAttribute('min', minDate);
                }

                if (expirationInput && dateOpenBtn) {
                    dateOpenBtn.addEventListener('click', () => {
                        if (typeof expirationInput.showPicker === 'function') {
                            expirationInput.showPicker();
                        } else {
                            expirationInput.focus();
                        }
                    });
                }
            });
        </script>
    {% endif %}
{% endblock %}
