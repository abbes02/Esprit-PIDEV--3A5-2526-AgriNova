<!DOCTYPE html>
<html>
<head>
    <title>agrinova</title>
    <meta charset="UTF-8">
    <style>
        * { margin: 0; padding: 0; }
        body { font-family: Arial; font-size: 12px; }
        table { width: 100%; border-collapse: collapse; }
        th, td { border: 1px solid black; padding: 5px; }
        th { background: #eee; }
        h1 { text-align: center; margin: 20px 0; }
    </style>
</head>
<body>
    <h1>agrinova</h1>
    <p style="text-align: center; font-size: 14px; margin-bottom: 20px;">Date: {{ "now"|date("d/m/Y") }}</p>
    <table>
        <tr>
            <th>ID</th>
            <th>Nom</th>
            <th>Type</th>
            <th>Parcelle</th>
            <th>Quantité</th>
            <th>Surface</th>
        </tr>
        {% for plante in plantes %}
        <tr>
            <td>{{ plante.idPlante }}</td>
            <td>{{ plante.nom }}</td>
            <td>{{ plante.type }}</td>
            <td>{{ plante.parcelle.localisation }}</td>
            <td>{{ plante.quantite }}</td>
            <td>{{ plante.surface }}</td>
        </tr>
        {% endfor %}
    </table>
</body>
</html>

