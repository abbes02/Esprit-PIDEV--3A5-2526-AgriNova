<form method="post" action="{{ path('app_location_delete', {'id': location.id, 'user_id': current_user.id}) }}" onsubmit="return confirm('Delete this location?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete_location_' ~ location.id) }}">
    <button class="button danger">Delete</button>
</form>
