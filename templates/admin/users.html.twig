{% extends 'base.html.twig' %}

{% block title %}Administration Utilisateurs | AgriNova{% endblock %}
{% block meta_description %}Interface d'administration des utilisateurs AgriNova.{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="/styles/agriculteur.css">
{% endblock %}

{% block javascripts %}
    <script src="/libs/gsap/gsap.min.js"></script>
    <script src="/libs/gsap/ScrollTrigger.min.js"></script>
    <script type="module" src="/scripts/agriculteur-scene.js"></script>
    <script src="/scripts/admin-users.js" defer></script>
{% endblock %}

{% block body %}
    <canvas id="bg" aria-hidden="true"></canvas>

    <main class="agri-page">
        <section class="admin-dashboard ui">
            <div class="admin-users-card glass parallax" data-speed="0.16">
                <div class="admin-dashboard-head">
                    <div>
                        <p class="eyebrow">Dashboard</p>
                        <h2 class="reveal-text">Utilisateurs</h2>
                    </div>

                    <div class="admin-summary">
                        <div class="admin-stat">
                            <span class="chip-label">Total</span>
                            <strong>{{ users|length }}</strong>
                        </div>
                        <div class="admin-stat">
                            <span class="chip-label">Agriculteurs</span>
                            <strong>{{ role_stats.AGRICULTEUR }}</strong>
                        </div>
                        <div class="admin-stat">
                            <span class="chip-label">Livreurs</span>
                            <strong>{{ role_stats.LIVREUR }}</strong>
                        </div>
                        <div class="admin-stat">
                            <span class="chip-label">Clients</span>
                            <strong>{{ role_stats.CLIENT }}</strong>
                        </div>
                        <div class="admin-stat admin-stat-profile">
                            <span class="chip-label">Admin</span>
                            <button
                                id="admin-profile-trigger"
                                class="admin-profile-trigger admin-profile-chip"
                                type="button"
                                aria-expanded="false"
                                aria-controls="admin-profile-panel"
                            >
                                <span class="user-avatar">
                                    <img src="{{ admin_profile.photo_url }}" alt="Photo de profil admin" onerror="this.style.display='none'; this.nextElementSibling.style.display='grid';">
                                    <span class="user-avatar-fallback">{{ admin_name|slice(0, 1)|upper }}</span>
                                </span>
                                <span class="user-meta">
                                    <span class="user-name">{{ admin_name }}</span>
                                    <span class="user-email">{{ admin_email }}</span>
                                </span>
                            </button>
                        </div>
                    </div>
                </div>

                {% for message in alerts.success %}
                    <p class="alert alert-success">{{ message }}</p>
                {% endfor %}

                {% for message in alerts.error %}
                    <p class="alert alert-error">{{ message }}</p>
                {% endfor %}

                <div class="admin-toolbar" style="margin-bottom: 1rem;">
                    <div class="admin-toolbar-meta">Connecte en tant que {{ admin_email }}</div>
                    <form method="post" action="/logout">
                        <button class="admin-logout-button" type="submit">Se deconnecter</button>
                    </form>
                </div>

                <div class="admin-filters">
                    <div class="admin-filter-field">
                        <label for="admin-search">Recherche</label>
                        <input id="admin-search" type="text" value="{{ search }}" placeholder="Nom, prenom, email, telephone">
                    </div>
                    <div class="admin-filter-field">
                        <label for="admin-sort">Tri alphabetique</label>
                        <select id="admin-sort">
                            <option value="ASC" {% if alphabetical == 'ASC' %}selected{% endif %}>A - Z</option>
                            <option value="DESC" {% if alphabetical == 'DESC' %}selected{% endif %}>Z - A</option>
                        </select>
                    </div>
                </div>

                <div class="admin-table-wrapper" style="margin-top: 1.2rem;">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Utilisateur</th>
                                <th>Email</th>
                                <th>Telephone</th>
                                <th>Date creation</th>
                                <th>Statut</th>
                                <th>Role</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="admin-users-body">
                            {% for user in users %}
                                <tr
                                    data-user-row
                                    data-user-name="{{ user.display_name|lower }}"
                                    data-search-text="{{ (user.display_name ~ ' ' ~ user.email ~ ' ' ~ user.phone ~ ' ' ~ user.status ~ ' ' ~ user.role)|lower }}"
                                >
                                    <td>
                                        <strong>{{ user.display_name }}</strong>
                                        {% if user.is_current_user %}
                                            <span class="role-chip">Compte courant</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ user.email }}</td>
                                    <td>{{ user.phone }}</td>
                                    <td>{{ user.created_at }}</td>
                                    <td>{{ user.status }}</td>
                                    <td>
                                        <form class="admin-inline-form" method="post" action="/admin/users/{{ user.id }}/role">
                                            <select name="role" {% if user.is_current_user %}disabled{% endif %}>
                                                {% for role in manageable_roles %}
                                                    <option value="{{ role }}" {% if user.role == role %}selected{% endif %}>{{ role }}</option>
                                                {% endfor %}
                                            </select>
                                            <button type="submit" {% if user.is_current_user %}disabled{% endif %}>Mettre a jour</button>
                                        </form>
                                    </td>
                                    <td>
                                        <form class="admin-delete-form" method="post" action="/admin/users/{{ user.id }}/delete" onsubmit="return confirm('Supprimer cet utilisateur ?');">
                                            <button class="button-danger" type="submit" {% if user.is_current_user %}disabled{% endif %}>Supprimer</button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

                <p id="admin-empty-state" class="admin-empty-state" {% if users is not empty %}hidden{% endif %}>
                    Aucun utilisateur ne correspond a la recherche.
                </p>
            </div>
        </section>

    </main>

    <div id="admin-profile-overlay" class="admin-profile-overlay" hidden></div>
    <aside id="admin-profile-panel" class="admin-profile-panel" aria-hidden="true">
        <div class="admin-profile-topbar">
            <div>
                <p class="eyebrow">Profil admin</p>
                <h3>{{ admin_profile.name }}</h3>
            </div>
            <button id="admin-profile-close" class="glass-btn" type="button">Fermer</button>
        </div>

        <section class="admin-profile-section">
            <p class="eyebrow">Informations</p>
            <h4>Modifier le profil</h4>
            <form class="auth-stack" method="post" action="/admin/profile/update" enctype="multipart/form-data">
                <div class="admin-profile-photo-row">
                    <div class="admin-profile-photo">
                        <img src="{{ admin_profile.photo_url }}" alt="Photo actuelle de l'admin" onerror="this.style.display='none'; this.nextElementSibling.style.display='grid';">
                        <span class="user-avatar-fallback">{{ admin_name|slice(0, 1)|upper }}</span>
                    </div>
                    <label for="photo">
                        Photo
                        <input id="photo" name="photo" type="file" accept="image/png,image/jpeg,image/webp,image/gif">
                    </label>
                </div>
                <div class="auth-row">
                    <label for="nom">
                        Nom
                        <input id="nom" name="nom" type="text" value="{{ admin_profile.first_name }}" required>
                    </label>
                    <label for="prenom">
                        Prenom
                        <input id="prenom" name="prenom" type="text" value="{{ admin_profile.last_name }}" required>
                    </label>
                </div>
                <label for="profile_email">
                    Email
                    <input id="profile_email" name="email" type="email" value="{{ admin_profile.email }}" required>
                </label>
                <button type="submit" class="primary-action">Mettre a jour le profil</button>
            </form>
        </section>

        <div class="admin-profile-grid">
            <div class="admin-profile-item" style="grid-column: 1 / -1;">
                <span class="chip-label">Nom</span>
                <strong>{{ admin_profile.name }}</strong>
                <span class="user-email" style="margin-top: 0.35rem; display: block;">{{ admin_profile.email }}</span>
            </div>
            <div class="admin-profile-item">
                <span class="chip-label">Role</span>
                <strong>{{ admin_profile.role }}</strong>
            </div>
            <div class="admin-profile-item">
                <span class="chip-label">Telephone</span>
                <strong>{{ admin_profile.phone }}</strong>
            </div>
            <div class="admin-profile-item">
                <span class="chip-label">Statut</span>
                <strong>{{ admin_profile.status }}</strong>
            </div>
            <div class="admin-profile-item">
                <span class="chip-label">Creation</span>
                <strong>{{ admin_profile.created_at }}</strong>
            </div>
            <div class="admin-profile-item" style="grid-column: 1 / -1;">
                <span class="chip-label">Adresse</span>
                <strong>{{ admin_profile.address }}</strong>
            </div>
        </div>

        <div class="admin-profile-sections">
            <section class="admin-profile-section">
                <p class="eyebrow">Securite</p>
                <h4>Changer le mot de passe</h4>
                <form class="auth-stack" method="post" action="/admin/profile/password">
                    <label for="current_password">
                        Mot de passe actuel
                        <input id="current_password" name="current_password" type="password" required>
                    </label>
                    <label for="new_password">
                        Nouveau mot de passe
                        <input id="new_password" name="new_password" type="password" minlength="6" required>
                    </label>
                    <label for="confirm_password">
                        Confirmation
                        <input id="confirm_password" name="confirm_password" type="password" minlength="6" required>
                    </label>
                    <button type="submit" class="primary-action">Mettre a jour</button>
                </form>
            </section>

            <section class="admin-profile-section admin-profile-section-danger">
                <p class="eyebrow">Suppression</p>
                <h4>Supprimer le compte</h4>
                <form class="auth-stack" method="post" action="/admin/profile/delete" onsubmit="return confirm('Supprimer definitivement le compte administrateur ?');">
                    <button type="submit" class="button-danger">Supprimer le compte</button>
                </form>
            </section>
        </div>
    </aside>
{% endblock %}
