<form method="post" action="{{ path('app_materiel_delete', {'id': materiel.id, 'user_id': current_user.id}) }}" onsubmit="return confirm('Delete this materiel?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete_materiel_' ~ materiel.id) }}">
    <button class="button danger">Delete</button>
</form>
