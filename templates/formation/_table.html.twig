{% for f in formations %}
<tr>
    <td style="font-weight:600;color:#c8e8c8">{{ f.titre }}</td>
    <td>{{ f.domaine }}</td>
    <td>{{ f.niveau }}</td>
    <td>{{ f.dureeHeures }} h</td>
    <td style="color:#7ed87e;font-weight:600">{{ f.prix }} €</td>
    <td>
        {% if f.statut == 'actif' %}
            <span class="badge badge-green">{{ f.statut }}</span>
        {% elseif f.statut == 'inactif' %}
            <span class="badge badge-red">{{ f.statut }}</span>
        {% else %}
            <span class="badge badge-gray">{{ f.statut }}</span>
        {% endif %}
    </td>
    <td>
        <div style="display:flex;gap:6px;flex-wrap:wrap">
            <a href="{{ path('formation_show', {id: f.id}) }}" class="btn btn-green btn-sm">👁 Voir</a>
            <a href="{{ path('formation_edit', {id: f.id}) }}" class="btn btn-green btn-sm">✏️ Modifier</a>
            <form method="post" action="{{ path('formation_delete', {id: f.id}) }}" style="display:inline"
                  onsubmit="return confirm('Supprimer cette formation ?')">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ f.id) }}">
                <button class="btn btn-green btn-sm">🗑 Supprimer</button>
            </form>
        </div>
    </td>
</tr>
{% else %}
<tr class="empty-row"><td colspan="7">Aucune formation trouvée.</td></tr>
{% endfor %}
