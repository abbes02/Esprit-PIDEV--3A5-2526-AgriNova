<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Agrinova — Accueil</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background: #0f1a12;
            color: #e8f5e9;
            font-family: 'Segoe UI', system-ui, sans-serif;
            overflow-x: hidden;
        }

        /* ── Canvas full-screen background ── */
        #bg {
            position: fixed;
            inset: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
        }

        .label-layer {
            position: fixed !important;
            inset: 0;
            pointer-events: none;
            z-index: 1;
        }

        .scene-label {
            background: rgba(10, 25, 12, 0.72);
            color: #a8e6a3;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 0.05em;
            padding: 3px 8px;
            border-radius: 4px;
            border: 1px solid rgba(100, 200, 100, 0.25);
            backdrop-filter: blur(4px);
            white-space: nowrap;
        }

        /* ── Top nav ── */
        nav {
            position: fixed;
            top: 0; left: 0; right: 0;
            z-index: 10;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 32px;
            background: rgba(10, 22, 12, 0.65);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(100, 200, 100, 0.12);
        }

        .nav-brand {
            font-size: 1.4rem;
            font-weight: 700;
            color: #7ed87e;
            letter-spacing: 0.04em;
            text-decoration: none;
        }

        .nav-links a {
            color: #b8ddb8;
            text-decoration: none;
            margin-left: 24px;
            font-size: 0.9rem;
            transition: color 0.2s;
        }
        .nav-links a:hover { color: #7ed87e; }

        /* ── Hero overlay ── */
        .hero {
            position: relative;
            z-index: 2;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 100px 24px 40px;
        }

        .hero-badge {
            display: inline-block;
            background: rgba(100, 200, 100, 0.12);
            border: 1px solid rgba(100, 200, 100, 0.3);
            color: #7ed87e;
            font-size: 0.75rem;
            font-weight: 600;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            padding: 5px 14px;
            border-radius: 20px;
            margin-bottom: 20px;
        }

        .hero h1 {
            font-size: clamp(2.4rem, 6vw, 4.2rem);
            font-weight: 800;
            line-height: 1.1;
            color: #e8f5e9;
            text-shadow: 0 2px 24px rgba(0,0,0,0.6);
            margin-bottom: 18px;
        }

        .hero h1 span { color: #7ed87e; }

        .hero p {
            max-width: 520px;
            font-size: 1.05rem;
            color: #a8c8a8;
            line-height: 1.7;
            margin-bottom: 36px;
        }

        .hero-cta {
            display: flex;
            gap: 14px;
            flex-wrap: wrap;
            justify-content: center;
        }

        .btn-primary-green {
            background: #3a8a3a;
            color: #fff;
            border: none;
            padding: 13px 30px;
            border-radius: 8px;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: background 0.2s, transform 0.15s;
        }
        .btn-primary-green:hover { background: #4aaa4a; transform: translateY(-2px); color: #fff; }

        .btn-outline-green {
            background: transparent;
            color: #7ed87e;
            border: 1.5px solid #7ed87e;
            padding: 12px 28px;
            border-radius: 8px;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: background 0.2s, transform 0.15s;
        }
        .btn-outline-green:hover { background: rgba(126,216,126,0.1); transform: translateY(-2px); color: #7ed87e; }

        /* ── Weather / Time controls ── */
        .scene-controls {
            position: fixed;
            bottom: 28px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 10;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
        }

        .control-group {
            display: flex;
            gap: 8px;
            background: rgba(10, 22, 12, 0.7);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(100, 200, 100, 0.15);
            border-radius: 40px;
            padding: 6px 10px;
        }

        .ctrl-btn {
            background: transparent;
            border: none;
            color: #8ab88a;
            font-size: 0.78rem;
            font-weight: 600;
            padding: 5px 14px;
            border-radius: 30px;
            cursor: pointer;
            transition: background 0.18s, color 0.18s;
            white-space: nowrap;
        }
        .ctrl-btn:hover  { background: rgba(100,200,100,0.12); color: #c8f0c8; }
        .ctrl-btn.active { background: rgba(100,200,100,0.22); color: #7ed87e; }

        /* ── Stats strip ── */
        .stats-strip {
            position: relative;
            z-index: 2;
            display: flex;
            justify-content: center;
            gap: 40px;
            flex-wrap: wrap;
            padding: 32px 24px;
            background: rgba(10, 22, 12, 0.55);
            backdrop-filter: blur(8px);
            border-top: 1px solid rgba(100,200,100,0.1);
        }

        .stat { text-align: center; }
        .stat-value { font-size: 2rem; font-weight: 800; color: #7ed87e; }
        .stat-label { font-size: 0.8rem; color: #7a9a7a; margin-top: 2px; letter-spacing: 0.05em; text-transform: uppercase; }

        /* ═══════════════════════════════════════════════
           Z-DEPTH SCROLL TUNNEL
        ═══════════════════════════════════════════════ */

        /*
         * The tunnel wrapper creates the 3D stage.
         * overflow:hidden clips anything that flies past the camera.
         * perspective-origin centers the vanishing point.
         */
        .z-tunnel {
            position: relative;
            z-index: 2;
            perspective: 900px;
            perspective-origin: 50% 50%;
            overflow: hidden;
            background: linear-gradient(180deg, transparent 0%, #0a1410 6%);
        }

        /*
         * Each section is a "depth layer" — it starts far away (translateZ negative)
         * and GSAP drives it toward the viewer as the user scrolls.
         * will-change: transform tells the browser to GPU-composite these.
         */
        .z-section {
            position: relative;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 80px 24px;
            transform-style: preserve-3d;
            will-change: transform;
        }

        /* The inner card that actually moves in Z */
        .z-card {
            position: relative;
            max-width: 860px;
            width: 100%;
            background: rgba(12, 26, 14, 0.82);
            border: 1px solid rgba(100, 200, 100, 0.14);
            border-radius: 18px;
            padding: 56px 60px;
            backdrop-filter: blur(14px);
            will-change: transform, opacity;
            /* starts invisible and far — JS sets the real values */
            opacity: 0;
            transform: translateZ(-320px) scale(0.72);
        }

        .z-card h2 {
            font-size: clamp(1.6rem, 3.5vw, 2.4rem);
            font-weight: 800;
            color: #e8f5e9;
            margin-bottom: 16px;
            line-height: 1.2;
        }
        .z-card h2 .accent { color: #7ed87e; }

        .z-card p {
            font-size: 1rem;
            color: #90b890;
            line-height: 1.75;
            max-width: 640px;
        }

        /* Decorative number behind each card */
        .z-card::before {
            content: attr(data-num);
            position: absolute;
            top: -28px; left: 40px;
            font-size: 7rem;
            font-weight: 900;
            color: rgba(92, 184, 92, 0.06);
            line-height: 1;
            pointer-events: none;
            user-select: none;
        }

        /* Feature grid inside a card */
        .feat-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 20px;
            margin-top: 32px;
        }
        .feat-item {
            background: rgba(92, 184, 92, 0.07);
            border: 1px solid rgba(92, 184, 92, 0.12);
            border-radius: 12px;
            padding: 20px 18px;
            will-change: transform, opacity;
        }
        .feat-item .fi-icon { font-size: 1.8rem; margin-bottom: 10px; }
        .feat-item .fi-title { font-size: 0.88rem; font-weight: 700; color: #c8e8c8; margin-bottom: 6px; }
        .feat-item .fi-desc  { font-size: 0.78rem; color: #7a9a7a; line-height: 1.5; }

        /* Scroll hint arrow */
        .scroll-hint {
            position: absolute;
            bottom: 28px; left: 50%;
            transform: translateX(-50%);
            z-index: 5;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
            color: rgba(126, 216, 126, 0.5);
            font-size: 0.72rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            animation: bounce 2s ease-in-out infinite;
            pointer-events: none;
        }
        .scroll-hint svg { width: 20px; opacity: 0.5; }

        @keyframes bounce {
            0%, 100% { transform: translateX(-50%) translateY(0); }
            50%       { transform: translateX(-50%) translateY(8px); }
        }

        /* Progress bar at top */
        #scroll-progress {
            position: fixed;
            top: 0; left: 0;
            height: 3px;
            width: 0%;
            background: linear-gradient(90deg, #3a7a3a, #7ed87e);
            z-index: 200;
            transition: width 0.1s linear;
        }
    </style>
</head>
<body>

<canvas id="bg"></canvas>
<div id="scroll-progress"></div>

{# ── Navigation ── #}
