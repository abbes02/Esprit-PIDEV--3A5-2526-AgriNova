                .severity-badge.major { background: #fef3d6; color: #9a6c00; }
                .severity-badge.critical { background: #fee2e2; color: #b91c1c; }

                /* Panne Grid */
                .panne-grid {
                    display: grid;
                    grid-template-columns: repeat(2, 1fr);
                    gap: 20px;
                    margin-bottom: 22px;
