{% extends 'parcelle/base.html.twig' %}

{% block title %}Formations{% endblock %}

{% block body %}
<section class="page-panel reveal">
    <div class="section-head">
        <div>
            <div class="section-kicker"><i class="bi bi-mortarboard"></i> Catalogue</div>
            <h1 class="page-title reveal-text">Formations</h1>
            <p class="page-intro">{{ formations|length }} resultat(s) disponibles.</p>
        </div>
        <div class="stack-sm">
            <a href="{{ path('formation_pdf', { q: q }) }}" class="button-secondary">Exporter PDF</a>
            <a href="{{ path('formation_new') }}" class="button-primary">Nouvelle formation</a>
        </div>
    </div>

    <form class="search-form mb-4" method="get">
        <div class="row g-3 align-items-end">
            <div class="col-md-8">
                <label for="formation-search">Recherche</label>
                <input
                    id="formation-search"
                    class="form-control"
                    type="search"
                    name="q"
                    value="{{ q }}"
                    placeholder="Titre, domaine, niveau, statut"
                >
            </div>
            <div class="col-md-4">
                <button class="button-primary w-100" type="submit">Rechercher</button>
            </div>
        </div>
    </form>

    <div class="table-shell">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Titre</th>
                        <th>Domaine</th>
                        <th>Niveau</th>
                        <th>Duree</th>
                        <th>Prix</th>
                        <th>Statut</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="table-body">
                    {% include 'formation/_table.html.twig' %}
                </tbody>
            </table>
        </div>
    </div>
</section>
{% endblock %}
