                /* ====== SEARCH & SORT TOOLBAR ====== */
                .search-sort-bar {
                    display: flex;
                    align-items: center;
                    gap: 12px;
                    margin-bottom: 20px;
                    padding: 12px 16px;
                    background: rgba(255,255,255,0.95);
