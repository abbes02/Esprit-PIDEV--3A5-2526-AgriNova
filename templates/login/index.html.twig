{% extends 'base.html.twig' %}

{% block title %}Connexion | AgriNova{% endblock %}
{% block meta_description %}Page de connexion AgriNova.{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="/styles/agriculteur.css">
{% endblock %}

{% block javascripts %}
    <script src="/libs/gsap/gsap.min.js"></script>
    <script src="/libs/gsap/ScrollTrigger.min.js"></script>
    <script type="module" src="/scripts/agriculteur-scene.js"></script>
{% endblock %}

{% block body %}
    <canvas id="bg" aria-hidden="true"></canvas>

    <main class="agri-page">
        <section class="auth-shell ui">
            <aside class="auth-box glass parallax" data-speed="0.12">
                <div>
                    <p class="eyebrow">AgriNova</p>
                    <h1 class="reveal-text">Connexion</h1>
                    <p class="hero-text">
                        Accedez a votre espace avec une connexion simple et directe.
                    </p>
                </div>

                {% if success_message %}
                    <p class="alert alert-success">{{ success_message }}</p>
                {% endif %}

                {% if error_message %}
                    <p class="alert alert-error">{{ error_message }}</p>
                {% endif %}

                <form class="auth-form" method="post" action="/login">
                    <label for="email">
                        Email
                        <input id="email" name="email" type="email" value="{{ submitted_email }}" placeholder="admin@agrinova.com" required>
                    </label>

                    <label for="password">
                        Mot de passe
                        <input id="password" name="password" type="password" placeholder="Mot de passe" required>
                    </label>

                    <div class="auth-links">
                        <span>Pas encore de compte ?</span>
                        <a href="/register" class="link">Creer un compte</a>
                    </div>

                    <button type="submit" class="primary-action">Se connecter</button>
                </form>
            </aside>
        </section>
    </main>
{% endblock %}
